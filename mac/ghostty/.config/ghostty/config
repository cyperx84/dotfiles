theme = Monokai Remastered
font-family = ZedMono NFM Bold
font-family-bold = Monaspace Radon ExtraBold
font-family-italic = Monaspace Radon Italic
font-family-bold-italic = Monaspace Krypton ExtraBold Italic
font-size = 12
font-feature = "ss01"
font-feature = "ss02"
font-feature = "ss03"
font-feature = "ss04"
font-feature = "liga"

cursor-color = #00FF00
cursor-style = block_hollow
cursor-style-blink = true

mouse-hide-while-typing = true
macos-titlebar-style = hidden
confirm-close-surface = false
background-opacity = 0.9
background-blur = false
unfocused-split-opacity = 1.0

macos-option-as-alt = true
window-step-resize = true
# grapheme-width-method = legacy

# Terminal integration improvements  
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# quick-terminal-size = 75%,85%
quick-terminal-size = 50%
quick-terminal-position = top
quick-terminal-animation-duration = 0.2
quick-terminal-autohide = true

macos-auto-secure-input = false
macos-secure-input-indication = false

# Keybinds
# Explicitly intercept Cmd+C/V/S for copy/paste - bypasses Kanata synthetic key issue
# where default cmd+<key> bindings don't match injected Cmd key events, letting
# them fall through to the terminal and get folded into tmux's Alt (M-) bindings
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+s=ignore
keybind = ctrl+l=unbind
keybind = cmd+shift+p=unbind
keybind = global:ctrl+enter=toggle_quick_terminal
# Send Esc+Enter so Hermes CLI treats Shift+Enter as an inserted newline.
keybind = shift+enter=text:\x1b\r
keybind = "cmd+shift+s=toggle_secure_input"

# Ghostty Custom shaders
custom-shader = shaders/cursor_smear_rainbow.glsl

# Per-machine overrides (uncommitted; gitignored). Loaded LAST so it wins.
# cursor-color above is the default/M4 green (#00FF00); on M1 the local file
# sets it blue. Optional (?) — machines without the file keep the default.
# See: mac/ghostty/.config/ghostty/local.conf (create per machine).
config-file = ?local.conf
