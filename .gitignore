# Compiled binaries
mac/sketchybar/.config/sketchybar/helper/helper

.genkit/
.DS_Store

# Backup files
*.bak
*.backup
*.archive
*~

# Runtime logs
.nvimlog
.aider*
__pycache__/

# Local/generated worktrees and plugin installs
.claude/worktrees/
mac/tmux/.tmux/plugins/
linux/tmux/.config/tmux/plugins/

# Per-machine ghostty overrides (e.g. cursor-color differs M1 vs M4)
mac/ghostty/.config/ghostty/local.conf

# Claude Code config now lives in its own repo: github.com/cyperx84/dotclaude

# herdr writes runtime logs + session state into its stowed config dir
# (~/.config/herdr → repo). Only config.toml is ours; never commit the rest
# (session.json can hold live session data — this repo is PUBLIC).
mac/herdr/.config/herdr/*
!mac/herdr/.config/herdr/config.toml
