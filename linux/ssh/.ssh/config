# SSH client config — managed in dotfiles (linux/ssh/.ssh/config), stowed to ~/.ssh/config.
# Host entries use Tailscale MagicDNS names; tailnet IPs kept as fallback comments.
# Mirrors mac/ssh/.ssh/config (minus the macOS-only colima include).
# Add a machine = add a Host block (and a matching sesh ssh entry).

# m4 Mac mini — provisioning machine
Host m4
    HostName m4-mini
    User cyperx
    # tailnet IP fallback: 100.74.220.17

# m1 Mac mini — desktop twin
Host m1
    HostName m1-mini
    User m1
    # tailnet IP fallback: 100.94.144.9

# omarchy — Linux on the tailnet
Host omarchy
    HostName omarchy
    User cyperx
    # tailnet IP fallback: 100.72.165.70

# Defaults for all hosts. accept-new auto-trusts a first-seen host key (no prompt
# on first connect) but still REJECTS a changed key — keeps MITM protection.
Host *
    StrictHostKeyChecking accept-new
