theme = Monokai Remastered
font-family = ZedMono NFM Bold
font-family-bold = Monaspace Radon ExtraBold
font-family-italic = Monaspace Radon Italic
font-family-bold-italic = Monaspace Krypton ExtraBold Italic
font-size = 20
font-feature = "ss01"
font-feature = "ss02"
font-feature = "ss03"
font-feature = "ss04"
font-feature = "liga"

cursor-color = #00FF00
cursor-style = block_hollow
cursor-style-blink = true

mouse-hide-while-typing = true
macos-titlebar-style = hidden
confirm-close-surface = false
background-opacity = 0.9
background-blur = false
unfocused-split-opacity = 1.0

macos-option-as-alt = true
window-step-resize = true
# grapheme-width-method = legacy

# Terminal integration improvements  
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# quick-terminal-size = 75%,85%
quick-terminal-size = 50%
quick-terminal-position = top
quick-terminal-animation-duration = 0.2
quick-terminal-autohide = true

macos-auto-secure-input = false
macos-secure-input-indication = false

# Keybinds
# Explicitly intercept Cmd+C for copy - bypasses Kanata synthetic key issue
# where super+c default binding doesn't match injected Cmd key events
keybind = cmd+c=copy_to_clipboard
keybind = ctrl+l=unbind
keybind = cmd+shift+p=unbind
keybind = global:ctrl+enter=toggle_quick_terminal
# Send Esc+Enter so Hermes CLI treats Shift+Enter as an inserted newline.
keybind = shift+enter=text:\x1b\r
keybind = "cmd+shift+s=toggle_secure_input"

# Ghostty Custom shaders
custom-shader = shaders/cursor_smear_rainbow.glsl
