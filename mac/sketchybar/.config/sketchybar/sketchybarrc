#!/usr/bin/env lua

-- SketchyBar config entry point (Lua / SbarLua).
-- The previous bash config is preserved alongside as `sketchybarrc.bash`.

-- Ensure the SbarLua module is built + installed (no-op if present).
os.execute("[ ! -f $HOME/.local/share/sketchybar_lua/sketchybar.so ] && " ..
  "(git clone https://github.com/FelixKratz/SbarLua.git /tmp/SbarLua && " ..
  "cd /tmp/SbarLua/ && make install && rm -rf /tmp/SbarLua/) || true")

-- Make the compiled module discoverable.
package.cpath = package.cpath .. ";" .. os.getenv("HOME") .. "/.local/share/sketchybar_lua/?.so"

-- Resolve requires relative to this config dir regardless of cwd.
package.path = package.path .. ";" .. os.getenv("HOME") .. "/.config/sketchybar/?.lua"

-- Global so item modules can use `sbar` directly.
sbar = require("sketchybar")

-- Batch the whole initial configuration into one message (fast startup).
sbar.begin_config()
require("init")
sbar.hotload(true)
sbar.end_config()

-- Run the event loop (required for Lua subscribe callbacks to fire).
sbar.event_loop()
