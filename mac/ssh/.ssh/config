# SSH client config — managed in dotfiles (mac/ssh/.ssh/config), stowed to ~/.ssh/config.
# Host entries use Tailscale MagicDNS names; tailnet IPs kept as fallback comments.
# Add a machine = add a Host block (and a matching sesh ssh entry).

# Colima (Docker) generated config. ~ keeps it portable across users/machines;
# OpenSSH silently skips it where the file doesn't exist (e.g. machines w/o colima).
Include ~/.colima/ssh_config

# m4 Mac mini — provisioning machine
Host m4
    HostName m4-mini
    User cyperx
    # tailnet IP fallback: 100.74.220.17

# m1 Mac mini — desktop twin
Host m1
    HostName m1-mini
    User m1
    # tailnet IP fallback: 100.94.144.9   | LAN fallback: m1.local

# omarchy — Linux on the tailnet
Host omarchy
    HostName omarchy
    User cyperx
    # tailnet IP fallback: 100.72.165.70
